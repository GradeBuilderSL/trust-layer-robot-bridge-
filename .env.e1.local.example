# Local E1 bootstrap settings.
# Copy to .env.e1.local on the Jetson and adjust only when needed.

export E1_ROBOT_ID="e1-01"
export E1_ROBOT_NAME="Noetix E1"
export E1_TRANSPORT="noetix_dds"
export E1_SERVER_PORT="8083"
export BRIDGE_PORT="8080"
export ROBOT_IP="127.0.0.1"
export ROBOT_PORT="8083"
export ROBOT_URL="http://127.0.0.1:8083"

# Override only when auto-detect fails.
# export E1_SDK_ROOT="/home/noetix/noetix_sdk_e1"
# export E1_DDS_CONFIG_PATH="/home/noetix/noetix_sdk_e1/config/dds.xml"
# export E1_SDK_LIB_DIR="/home/noetix/noetix_sdk_e1/lib/aarch64"
# export E1_DDS_HELPER_PATH="/home/noetix/trust-layer-robot-bridge-/native/build/e1_dds_bridge"

# Bootstrap behavior.
export E1_BOOTSTRAP_INSTALL_DEPS="1"
export E1_BOOTSTRAP_BUILD_HELPER="1"
export E1_BOOTSTRAP_START_STACK="1"
export E1_BOOTSTRAP_COLLECT_TELEMETRY="1"
export E1_BOOTSTRAP_WAIT_SEC="20"
export E1_BOOTSTRAP_INSTALL_SPEECH="0"
